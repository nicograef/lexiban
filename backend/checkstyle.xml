<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Checkstyle Config — ≈ .eslintrc for Java.

  Based on Google Java Style, adjusted for this project:
  - 4-space indent (AOSP style, matching Spotless config)
  - 120-char line width (more practical than Google's 100)
  - No mandatory Javadoc (this is a learning project, not a library)

  Full module reference: https://checkstyle.org/checks.html
-->
<module name="Checker">
    <!-- File-level checks (run on every .java file) -->

    <!-- No tab characters — use spaces only (≈ EditorConfig indent_style=space) -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- Files must end with a newline (≈ EditorConfig insert_final_newline=true) -->
    <module name="NewlineAtEndOfFile"/>

    <!-- Max line length: 120 chars. Enough for readable code without horizontal scrolling.
         Ignore import statements and URLs — they can be long. -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^import |^package |https?://"/>
    </module>

    <!-- ── AST-level checks (inside the TreeWalker) ── -->
    <module name="TreeWalker">

        <!-- ═══ Naming Conventions ═══
             ≈ ESLint naming-convention rule -->

        <!-- Classes/Interfaces: PascalCase (e.g., IbanService, IbanNumber) -->
        <module name="TypeName"/>

        <!-- Methods: camelCase (e.g., validateIban, findById) -->
        <module name="MethodName"/>

        <!-- Local variables: camelCase -->
        <module name="LocalVariableName"/>

        <!-- Parameters: camelCase -->
        <module name="ParameterName"/>

        <!-- Member variables: camelCase (e.g., ibanService, not m_ibanService) -->
        <module name="MemberName"/>

        <!-- Constants (static final): UPPER_SNAKE_CASE (e.g., MAX_IBAN_LENGTH).
             Exception: loggers are conventionally lowercase (log, logger). -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$|^log(ger)?$"/>
        </module>

        <!-- Package names: all lowercase (e.g., de.nicograef.iban.service) -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- ═══ Imports ═══ -->

        <!-- No wildcard imports like "import java.util.*" (≈ ESLint no-restricted-imports) -->
        <module name="AvoidStarImport"/>

        <!-- No redundant imports -->
        <module name="RedundantImport"/>

        <!-- No unused imports (≈ ESLint no-unused-vars for imports) -->
        <module name="UnusedImports"/>

        <!-- ═══ Code Style ═══ -->

        <!-- Require braces for if/for/while/do — even one-liners
             ≈ ESLint curly: "all" -->
        <module name="NeedBraces"/>

        <!-- Opening brace on same line: if (x) { not if (x)\n{
             ≈ ESLint brace-style: "1tbs" -->
        <module name="LeftCurly"/>

        <!-- Closing brace rules (else on same line as }) -->
        <module name="RightCurly"/>

        <!-- ═══ Whitespace ═══ -->

        <!-- Space after comma, semicolon -->
        <module name="WhitespaceAfter"/>

        <!-- Space around operators: a + b, not a+b -->
        <module name="WhitespaceAround">
            <!-- Allow empty method bodies: void noop() {} -->
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
        </module>

        <!-- No whitespace after unary operators: !x, -y (not ! x, - y) -->
        <module name="NoWhitespaceAfter"/>

        <!-- No whitespace before comma, semicolon -->
        <module name="NoWhitespaceBefore"/>

        <!-- ═══ Best Practices ═══ -->

        <!-- No empty catch blocks (≈ ESLint no-empty) -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignored"/>
        </module>

        <!-- One top-level class per file (standard Java convention) -->
        <module name="OneTopLevelClass"/>

        <!-- Modifier order: public static final, not final public static
             (≈ standard Java convention) -->
        <module name="ModifierOrder"/>

        <!-- No multiple statements on same line -->
        <module name="OneStatementPerLine"/>

        <!-- Suppress warnings via @SuppressWarnings annotation if needed -->
        <module name="SuppressWarningsHolder"/>
    </module>

    <!-- Allow @SuppressWarnings("checkstyle:RuleName") to suppress specific checks -->
    <module name="SuppressWarningsFilter"/>
</module>
